generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Game {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  type        String   @default("trivia") // "trivia", "lightning", "prediction", "poll", etc.
  config      String?  // JSON string with game-specific config
  isActive    Boolean  @default(true)
  order       Int      @default(0) // display order
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  participants Participant[]
}

model Participant {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  code        String   @unique
  gameId      String?
  game        Game?    @relation(fields: [gameId], references: [id])
  followedFb  Boolean  @default(false)
  followedIg  Boolean  @default(false)
  followedWa  Boolean  @default(false)
  totalPoints Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TriviaQuestion {
  id          String   @id @default(cuid())
  question    String
  optionA     String
  optionB     String
  optionC     String
  optionD     String
  correctAnswer String  // "A", "B", "C", or "D"
  category    String?  // e.g. "estadios", "fundacion", "apodos", etc.
  teamSlug    String?  // related team
  difficulty  String   @default("medium") // "easy", "medium", "hard"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  answers     TriviaAnswer[]
  rounds      TriviaRound[]
}

model TriviaAnswer {
  id          String   @id @default(cuid())
  questionId  String
  question    TriviaQuestion @relation(fields: [questionId], references: [id])
  participantCode String  // TPK code
  selectedAnswer String  // "A", "B", "C", or "D"
  isCorrect   Boolean
  pointsEarned Int     @default(0)
  roundId     String   // hour-based round identifier (e.g. "2026-04-30-14")
  createdAt   DateTime @default(now())

  @@unique([questionId, participantCode, roundId])
}

model TriviaRound {
  id          String   @id @default(cuid())
  roundId     String   @unique // e.g. "2026-04-30-14"
  questionId  String
  question    TriviaQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  startedAt   DateTime
  endsAt      DateTime
  createdAt   DateTime @default(now())
}

// ============================================
// TRIVIA RELÁMPAGO - 5 preguntas en 60 segundos
// ============================================

model LightningRound {
  id            String   @id @default(cuid())
  roundId       String   @unique // e.g. "L-2026-04-30-14"
  questionIds   String   // JSON array of 5 question indices from lightning-questions bank
  startedAt     DateTime
  endsAt        DateTime
  createdAt     DateTime @default(now())
  answers       LightningAnswer[]
}

model LightningAnswer {
  id              String   @id @default(cuid())
  roundId         String
  round           LightningRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  participantCode String   // TPK code
  questionIndex   Int      // 0-4, index within the 5-question set
  selectedAnswer  String   // "A", "B", "C", or "D"
  isCorrect       Boolean
  pointsEarned    Int      @default(0)
  speedBonus      Int      @default(0) // bonus for fast answers
  timeToAnswer    Int      @default(0) // ms taken to answer this question
  createdAt       DateTime @default(now())

  @@unique([roundId, participantCode, questionIndex])
}

model LightningSession {
  id              String   @id @default(cuid())
  roundId         String
  participantCode String
  totalCorrect    Int      @default(0)
  totalPoints     Int      @default(0)
  totalBonus      Int      @default(0)
  totalTimeMs     Int      @default(0) // total time in ms
  completedAt     DateTime @default(now())

  @@unique([roundId, participantCode])
}

// ============================================
// POPUP CIRCULAR - Banner animado editable
// ============================================

model PopupConfig {
  id          String   @id @default(cuid())
  text        String   @default("TPK NUEVO")
  linkUrl     String   @default("#")
  imageUrl    String?  @default("https://placehold.co/300x300/1a0a2e/f97316?text=TPK")
  isActive    Boolean  @default(true)
  color       String   @default("#f97316")
  size        Int      @default(120)
  position    String   @default("bottom-left")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
