generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Game {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  type        String   @default("trivia") // "trivia", "lightning", "prediction", "poll", etc.
  config      String?  // JSON string with game-specific config
  isActive    Boolean  @default(true)
  order       Int      @default(0) // display order
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  participants Participant[]
}

model Participant {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  code        String   @unique
  teamSlug    String   @default("")     // Equipo hincha - obligatorio al registrarse
  gameId      String?
  game        Game?    @relation(fields: [gameId], references: [id])
  followedFb  Boolean  @default(false)
  followedIg  Boolean  @default(false)
  followedWa  Boolean  @default(false)
  totalPoints Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TriviaQuestion {
  id          String   @id @default(cuid())
  question    String
  optionA     String
  optionB     String
  optionC     String
  optionD     String
  correctAnswer String  // "A", "B", "C", or "D"
  category    String?  // e.g. "estadios", "fundacion", "apodos", etc.
  teamSlug    String?  // related team
  difficulty  String   @default("medium") // "easy", "medium", "hard"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  answers     TriviaAnswer[]
  rounds      TriviaRound[]
}

model TriviaAnswer {
  id          String   @id @default(cuid())
  questionId  String
  question    TriviaQuestion @relation(fields: [questionId], references: [id])
  participantCode String  // TPK code
  selectedAnswer String  // "A", "B", "C", or "D"
  isCorrect   Boolean
  pointsEarned Int     @default(0)
  roundId     String   // hour-based round identifier (e.g. "2026-04-30-14")
  createdAt   DateTime @default(now())

  @@unique([questionId, participantCode, roundId])
}

model TriviaRound {
  id          String   @id @default(cuid())
  roundId     String   @unique // e.g. "2026-04-30-14"
  questionId  String
  question    TriviaQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  startedAt   DateTime
  endsAt      DateTime
  createdAt   DateTime @default(now())
}

// ============================================
// TRIVIA RELÁMPAGO - 5 preguntas en 60 segundos
// ============================================

model LightningRound {
  id            String   @id @default(cuid())
  roundId       String   @unique // e.g. "L-2026-04-30-14"
  questionIds   String   // JSON array of 5 question indices from lightning-questions bank
  startedAt     DateTime
  endsAt        DateTime
  createdAt     DateTime @default(now())
  answers       LightningAnswer[]
}

model LightningAnswer {
  id              String   @id @default(cuid())
  roundId         String
  round           LightningRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  participantCode String   // TPK code
  questionIndex   Int      // 0-4, index within the 5-question set
  selectedAnswer  String   // "A", "B", "C", or "D"
  isCorrect       Boolean
  pointsEarned    Int      @default(0)
  speedBonus      Int      @default(0) // bonus for fast answers
  timeToAnswer    Int      @default(0) // ms taken to answer this question
  createdAt       DateTime @default(now())

  @@unique([roundId, participantCode, questionIndex])
}

model LightningSession {
  id              String   @id @default(cuid())
  roundId         String
  participantCode String
  totalCorrect    Int      @default(0)
  totalPoints     Int      @default(0)
  totalBonus      Int      @default(0)
  totalTimeMs     Int      @default(0) // total time in ms
  completedAt     DateTime @default(now())

  @@unique([roundId, participantCode])
}

// ============================================
// POPUP CIRCULAR - Banner animado editable
// ============================================

model PopupConfig {
  id          String   @id @default(cuid())
  text        String   @default("TPK NUEVO")
  linkUrl     String   @default("#")
  imageUrl    String?  @default("https://placehold.co/300x300/1a0a2e/f97316?text=TPK")
  isActive    Boolean  @default(true)
  color       String   @default("#f97316")
  size        Int      @default(120)
  position    String   @default("bottom-left")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// BANNERS TPK - GANADOR TPK y PREMIO TPK
// ============================================

model TpkBanner {
  id          String   @id @default(cuid())
  type        String   @unique // "ganador" or "premio"
  title       String   // e.g. "GANADOR TPK", "PREMIO TPK"
  subtitle    String?  // e.g. "Campeón Semanal", "Zapatillas Nike personalizadas"
  imageUrl    String?  // URL de la foto del ganador o premio
  linkUrl     String?  // Enlace opcional
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// PREDICCIONES - Resultados de partidos Liga BetPlay
// ============================================

model MatchPrediction {
  id          String   @id @default(cuid())
  homeTeam    String   // slug del equipo local (ej: "millonarios")
  awayTeam    String   // slug del equipo visitante (ej: "atletico-nacional")
  homeScore   Int?     // marcador local (null si no se ha jugado)
  awayScore   Int?     // marcador visitante (null si no se ha jugado)
  matchDate   DateTime // fecha y hora del partido
  venue       String?  // estadio/sede
  status      String   @default("upcoming") // "upcoming", "live", "finished"
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// LOTERÍA DE EQUIPOS - Configuración del juego
// ============================================

model LoteriaConfig {
  id          String   @id @default(cuid())
  boardSize   Int      @default(4)      // 3, 4, o 5 (grid: 3x3, 4x4, 5x5)
  pointsLine  Int      @default(30)     // Puntos por línea horizontal/vertical
  pointsDiag  Int      @default(50)     // Puntos por diagonal
  pointsFull  Int      @default(100)    // Puntos por lotería completa
  drawSpeed   Int      @default(5)      // Segundos entre cada sorteo
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// RULETA DE EQUIPOS - Configuración del juego
// ============================================

model RuletaConfig {
  id              String   @id @default(cuid())
  pointsExact     Int      @default(50)     // Puntos por acertar escudo exacto
  pointsRegion    Int      @default(10)     // Puntos por escudo de misma región
  spinDuration    Int      @default(4)      // Duración del giro en segundos
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// CIRCUITO FUTBOLERO - Configuración del juego
// ============================================

model CircuitoConfig {
  id              String   @id @default(cuid())
  pointsDot       Int      @default(10)     // Puntos por balón recogido
  pointsGhost     Int      @default(200)    // Puntos por rival eliminado
  gameSpeed       Int      @default(3)      // Velocidad 1-5
  lives           Int      @default(3)      // Vidas por partida
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// PARQUÉS FUTBOLERO - Configuración del juego
// ============================================

model ParquesConfig {
  id              String   @id @default(cuid())
  tokensPerPlayer Int      @default(2)      // Fichas por jugador (2 o 4)
  pointsCapture   Int      @default(50)     // Puntos por capturar rival
  pointsFinish    Int      @default(100)    // Puntos por llegar a la meta
  pointsWin       Int      @default(500)    // Puntos por ganar la partida
  diceSpeed       Int      @default(3)      // Velocidad de animación del dado 1-5
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// PARQUÉS FUTBOLERO - Salas multijugador
// ============================================

model ParquesRoom {
  id              String   @id @default(cuid())
  roomCode        String   @unique            // Código de 6 caracteres para compartir
  clasicoMode     String   @default("rivales-historicos") // Modo de clásico seleccionado
  status          String   @default("waiting") // "waiting", "playing", "finished"
  currentPlayer   Int      @default(0)        // Índice del jugador actual (0-3)
  gameState       String   @default("{}")     // JSON: estado completo del juego (tokens, dado, etc.)
  winnerPlayerIdx Int      @default(-1)       // Índice del ganador (-1 si no hay)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  players         ParquesRoomPlayer[]
}

model ParquesRoomPlayer {
  id              String   @id @default(cuid())
  roomId          String
  room            ParquesRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  participantCode String                        // Código TPK del participante
  participantName String                        // Nombre del participante (cache)
  teamSlug        String                        // Escudo de equipo elegido
  playerIndex     Int                           // Posición en el tablero (0-3)
  isCreator       Boolean  @default(false)      // Quien creó la sala
  score           Int      @default(0)          // Puntos acumulados en la partida
  joinedAt        DateTime @default(now())

  @@unique([roomId, participantCode])
  @@unique([roomId, playerIndex])
}

// ============================================
// ROMPECABEZAS DE ESCUDOS - Configuración del juego
// ============================================

model RompecabezasConfig {
  id              String   @id @default(cuid())
  gridSize        Int      @default(6)      // Grid: 4=fácil, 5=medio, 6=complejo
  pointsComplete  Int      @default(200)    // Puntos por completar el rompecabezas
  timeBonusMax    Int      @default(100)    // Bonus máximo por tiempo (se reduce con cada segundo)
  timeLimit       Int      @default(300)    // Tiempo límite en segundos (0 = sin límite)
  showPreview     Boolean  @default(true)   // Mostrar imagen de referencia
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// PENALES FUTBOLEROS - Configuración del juego
// ============================================

model PenalesConfig {
  id              String   @id @default(cuid())
  roundsPerGame   Int      @default(5)      // Penales por ronda
  pointsGoal      Int      @default(20)     // Puntos por gol
  pointsHatTrick  Int      @default(50)     // Bonus hat-trick
  pointsPerfect   Int      @default(100)    // Ronda perfecta
  timeLimit       Int      @default(60)     // Segundos para cada tiro
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// CARTA MAYOR - Configuración del juego
// ============================================

model CartaMayorConfig {
  id              String   @id @default(cuid())
  cardsPerRound   Int      @default(10)     // Cartas por ronda
  pointsCorrect   Int      @default(10)     // Puntos por acierto
  pointsStreak5   Int      @default(50)     // Bonus racha x5
  pointsStreak10  Int      @default(200)    // Bonus racha x10
  timeLimit       Int      @default(120)    // Tiempo límite en segundos
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// DIANA DE ESCUDOS - Configuración del juego
// ============================================

model DianaConfig {
  id              String   @id @default(cuid())
  roundsPerGame   Int      @default(10)     // Tiros por partida
  pointsCenter    Int      @default(50)     // Puntos centro
  pointsMiddle    Int      @default(30)     // Puntos medio
  pointsEdge      Int      @default(10)     // Puntos borde
  speed           Int      @default(3)      // Velocidad 1-5
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// CLASIFICACIÓN HISTÓRICA - Configuración del juego
// ============================================

model ClasificacionConfig {
  id              String   @id @default(cuid())
  teamsPerRound   Int      @default(6)      // Equipos a ordenar
  pointsPerfect   Int      @default(150)    // Orden perfecto
  pointsPartial   Int      @default(80)     // 1 error
  timeLimit       Int      @default(120)    // Tiempo límite
  timeBonusMax    Int      @default(50)     // Bonus máximo por tiempo
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// NÚMERO CAMISETA - Configuración del juego
// ============================================

model NumeroCamisetaConfig {
  id              String   @id @default(cuid())
  questionsPerGame Int     @default(5)      // Preguntas por partida
  pointsExact     Int      @default(40)     // Puntos número exacto
  pointsClose     Int      @default(20)     // Puntos ±2
  noHintMultiplier Int     @default(2)      // Multiplicador sin pista
  timeLimit       Int      @default(90)     // Tiempo límite
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// MINERÍA DE ESCUDOS - Configuración del juego
// ============================================

model MineriaConfig {
  id              String   @id @default(cuid())
  gridSize        Int      @default(8)      // Grid: 6=fácil, 8=medio, 10=complejo
  mineCount       Int      @default(10)     // Número de minas (rivales)
  pointsPerCell   Int      @default(5)      // Puntos por casilla segura
  pointsComplete  Int      @default(100)    // Puntos por completar
  pointsNoMines   Int      @default(50)     // Bonus sin detonar
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// APUESTA FUTBOLERA - Configuración del juego
// ============================================

model ApuestaConfig {
  id              String   @id @default(cuid())
  matchesPerRound Int      @default(3)      // Partidos por ronda
  pointsExact     Int      @default(60)     // Resultado exacto
  pointsWinner    Int      @default(20)     // Ganador correcto
  pointsGoals     Int      @default(30)     // Goles exactos extra
  timeLimit       Int      @default(180)    // Tiempo límite
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// SOPA DE ESCUDOS - Configuración del juego
// ============================================

model SopaConfig {
  id              String   @id @default(cuid())
  gridSize        Int      @default(12)     // Grid: 10=fácil, 12=medio, 14=complejo
  wordsPerGame    Int      @default(8)      // Palabras por partida
  pointsPerWord   Int      @default(15)     // Puntos por palabra
  pointsComplete  Int      @default(100)    // Bonus completar todas
  timeLimit       Int      @default(180)    // Tiempo límite
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// AUDIO PLAYER - Configuración del reproductor
// ============================================

model AudioConfig {
  id          String   @id @default(cuid())
  audioUrl    String   @default("/tpk-anthem.mp3")  // Ruta del archivo de audio
  volume      Int      @default(60)                  // Volumen 0-100
  autoPlay    Boolean  @default(false)               // Auto-reproducir al interactuar
  isActive    Boolean  @default(true)                // Audio activado/desactivado
  label       String   @default("Te Pe Ka Fans Club") // Nombre mostrado
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
